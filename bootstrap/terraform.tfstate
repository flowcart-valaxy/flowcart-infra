            "id": "3493702042",
            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Sid\": \"DenyAllOutsideAllowedRegions\",\n      \"Effect\": \"Deny\",\n      \"NotAction\": [\n        \"trustedadvisor:*\",\n        \"tag:*\",\n        \"support:*\",\n        \"sts:*\",\n        \"route53:*\",\n        \"organizations:*\",\n        \"kms:*\",\n        \"iam:*\",\n        \"health:*\",\n        \"globalaccelerator:*\",\n        \"ec2:DescribeRegions\",\n        \"ec2:DescribeAccountAttributes\",\n        \"cloudfront:*\"\n      ],\n      \"Resource\": \"*\",\n      \"Condition\": {\n        \"StringNotEquals\": {\n          \"aws:RequestedRegion\": \"us-east-1\"\n        }\n      }\n    },\n    {\n      \"Sid\": \"DenyIAMUserCreation\",\n      \"Effect\": \"Deny\",\n      \"Action\": [\n        \"iam:CreateUser\",\n        \"iam:CreateLoginProfile\",\n        \"iam:CreateAccessKey\"\n      ],\n      \"Resource\": \"*\"\n    }\n  ]\n}",
            "minified_json": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Sid\":\"DenyAllOutsideAllowedRegions\",\"Effect\":\"Deny\",\"NotAction\":[\"trustedadvisor:*\",\"tag:*\",\"support:*\",\"sts:*\",\"route53:*\",\"organizations:*\",\"kms:*\",\"iam:*\",\"health:*\",\"globalaccelerator:*\",\"ec2:DescribeRegions\",\"ec2:DescribeAccountAttributes\",\"cloudfront:*\"],\"Resource\":\"*\",\"Condition\":{\"StringNotEquals\":{\"aws:RequestedRegion\":\"us-east-1\"}}},{\"Sid\":\"DenyIAMUserCreation\",\"Effect\":\"Deny\",\"Action\":[\"iam:CreateUser\",\"iam:CreateLoginProfile\",\"iam:CreateAccessKey\"],\"Resource\":\"*\"}]}",
            "override_json": null,
            "override_policy_documents": null,
            "policy_id": null,
            "source_json": null,
            "source_policy_documents": null,
            "statement": [
              {
                "actions": [],
