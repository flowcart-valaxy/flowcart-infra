          "schema_version": 0,
          "attributes": {
            "id": "1224326283",
            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Sid\": \"DenyDestructiveActionsOutsideDeployer\",\n      \"Effect\": \"Deny\",\n      \"Action\": [\n        \"s3:DeleteBucket\",\n        \"rds:DeleteDBInstance\",\n        \"rds:DeleteDBClusterSnapshot\",\n        \"rds:DeleteDBCluster\",\n        \"kms:ScheduleKeyDeletion\",\n        \"kms:DisableKey\",\n        \"elasticache:DeleteReplicationGroup\",\n        \"elasticache:DeleteCacheCluster\",\n        \"eks:DeleteNodegroup\",\n        \"eks:DeleteCluster\"\n      ],\n      \"Resource\": \"*\",\n      \"Condition\": {\n        \"StringNotLike\": {\n          \"aws:PrincipalARN\": [\n            \"arn:aws:iam::*:role/TerraformDeployer\",\n            \"arn:aws:iam::*:role/BreakGlassAdmin\"\n          ]\n        }\n      }\n    }\n  ]\n}",
            "minified_json": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Sid\":\"DenyDestructiveActionsOutsideDeployer\",\"Effect\":\"Deny\",\"Action\":[\"s3:DeleteBucket\",\"rds:DeleteDBInstance\",\"rds:DeleteDBClusterSnapshot\",\"rds:DeleteDBCluster\",\"kms:ScheduleKeyDeletion\",\"kms:DisableKey\",\"elasticache:DeleteReplicationGroup\",\"elasticache:DeleteCacheCluster\",\"eks:DeleteNodegroup\",\"eks:DeleteCluster\"],\"Resource\":\"*\",\"Condition\":{\"StringNotLike\":{\"aws:PrincipalARN\":[\"arn:aws:iam::*:role/TerraformDeployer\",\"arn:aws:iam::*:role/BreakGlassAdmin\"]}}}]}",
            "override_json": null,
            "override_policy_documents": null,
            "policy_id": null,
            "source_json": null,
            "source_policy_documents": null,
            "statement": [
              {
                "actions": [
                  "eks:DeleteCluster",
                  "eks:DeleteNodegroup",
                  "elasticache:DeleteCacheCluster",
                  "elasticache:DeleteReplicationGroup",
                  "kms:DisableKey",
                  "kms:ScheduleKeyDeletion",
                  "rds:DeleteDBCluster",
                  "rds:DeleteDBClusterSnapshot",
                  "rds:DeleteDBInstance",
                  "s3:DeleteBucket"
                ],
                "condition": [
                  {
                    "test": "StringNotLike",
                    "values": [
                      "arn:aws:iam::*:role/TerraformDeployer",
                      "arn:aws:iam::*:role/BreakGlassAdmin"
                    ],
                    "variable": "aws:PrincipalARN"
                  }
                ],
                "effect": "Deny",
                "not_actions": [],
                "not_principals": [],
                "not_resources": [],
                "principals": [],
                "resources": [
                  "*"
                ],
                "sid": "DenyDestructiveActionsOutsideDeployer"
              }
            ],
            "version": "2012-10-17"
          },
          "sensitive_attributes": [],
          "identity_schema_version": 0
        }
      ]
